  "threats": [
    {
      "id": "T1",
      "title": "Forged Slack request",
      "affected_components": ["fastapi"],
      "severity": "high",
      "mitigation": "Verify X-Slack-Signature on all /slack/* routes before processing"
    },
    {
      "id": "T2",
      "title": "Snapshot token enumeration",
      "affected_components": ["fastapi", "vp"],
      "severity": "medium",
      "mitigation": "Token is 32 random bytes; regeneration available if over-shared"
    },
    {
      "id": "T3",
      "title": "Session hijacking",
      "affected_components": ["fastapi", "engineer"],
      "severity": "medium",
      "mitigation": "HTTP-only + Secure + SameSite=Lax cookies; server-side session revocation"
    },
    {
      "id": "T4",
      "title": "Insider card update for another engineer",
      "affected_components": ["fastapi"],
      "severity": "low",
      "mitigation": "API enforces engineer_id == session.engineer_id for card writes"
    }
  ]
