    {"id": "team_lead", "label": "Team Lead", "type": "human"},
    {"id": "vp", "label": "VP", "type": "human"},
    {"id": "attacker", "label": "Attacker", "type": "adversarial"}
  ],
  "flows": [
    {"from": "engineer", "to": "nginx", "label": "HTTPS (browser + Slack)"},
    {"from": "vp", "to": "nginx", "label": "HTTPS (snapshot token)"},
    {"from": "slack_api", "to": "nginx", "label": "Webhook (signed)"},
    {"from": "nginx", "to": "fastapi", "label": "Proxy"},
