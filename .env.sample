# You can explicitly select your provider by setting this variable; otherwise, Clarity will
# auto-detect based on which credentials and SDKs it finds. If you set this, it must be one
# of the supported providers: anthropic, claude-sdk, openai, or azure.

# CLARITY_LLM_PROVIDER=azure

# API keys: If you're using an LLM provider that requires an API key, set it here. If you're
# using a non-key method like `claude login` or `az login`, don't set this.
# ANTHROPIC_API_KEY=your-api-key-here
# OPENAI_API_KEY=your-api-key-here
# AZURE_AI_API_KEY=your-api-key-here
# AZURE_AI_ENDPOINT=your-endpoint-here (e.g. https://your-resource

# Azure OpenAI (pick one auth method):
# Option A — API key:
# AZURE_AI_API_KEY=your-key-here
# AZURE_AI_ENDPOINT=https://your-resource.openai.azure.com
#
# Option B — Azure AD (az login / DefaultAzureCredential):
# AZURE_AI_ENDPOINT=https://your-resource.openai.azure.com
# (No API key needed — uses az login, managed identity, etc.)

# Model tier overrides (optional)
# Each tier maps to a concrete model string. Processes are assigned to tiers
# based on their reasoning demands; override here to change which model a
# tier uses.
# CLARITY_MODEL_DEEP=claude-opus-4-20250514
# CLARITY_MODEL_FAST=claude-haiku-4-5-20251001

# Per-process model overrides (optional)
# Value is either a tier name ("deep", "fast", "default") or a direct model
# string. Use underscores for process names (they map to hyphens internally).
# CLARITY_PROCESS_MODEL_problem_clarification=deep
# CLARITY_PROCESS_MODEL_architecture_design=o1-preview

# UI theme (optional). Overridden by --theme on the CLI.
# CLARITY_THEME=sage